# Public site URL used for canonical links and metadata.
PUBLIC_SITE_URL=https://dhaf.in
ASTRO_TELEMETRY_DISABLED=1
BUN_VERSION=1.3.5

# Draft preview auth. Keep both server-only.
PREVIEW_SECRET=
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=

# Sanity Studio and content API configuration.
# Replace locally and in Cloudflare with the real project ID from Sanity Manage.
SANITY_STUDIO_PROJECT_ID=your_sanity_project_id
SANITY_STUDIO_DATASET=production
SANITY_API_VERSION=2025-02-19
