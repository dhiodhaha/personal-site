---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: 'profile' | 'website' | 'article';
}

const {
  title = 'Dhafin',
  description = 'Product-shaped ideas into usable web experiences.',
  image,
  noindex = false,
  type = 'website',
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://dhaf.in';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const socialImageUrl = new URL(image ?? '/og-default.svg', siteUrl);
const pageTitle = title === 'Dhafin' ? title : `${title} | Dhafin`;
---

<!doctype html>
<html lang="en" class="antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:site_name" content="Dhafin" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImageUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.toString()} />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />
  </head>
  <body>
    <div class="custom-cursor" aria-hidden="true">
      <span class="custom-cursor-dot"></span>
      <span class="custom-cursor-label">view</span>
    </div>
    <header class="site-header">
      <div class="page-shell site-header-inner">
        <a class="site-brand" href="/" aria-label="Homepage">DHAFIN</a>
        <nav class="site-nav" aria-label="Primary">
          <a class="site-nav-link" href="/work">WORK</a>
          <a class="site-nav-link" href="/writing">PLAYGROUND</a>
          <a class="site-nav-link" href="/about">ABOUT</a>
        </nav>
      </div>
    </header>
    <main class="page-shell site-main isolate">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="page-shell site-footer-inner">
        <span>DHAFIN</span>
        <nav class="site-footer-links" aria-label="Footer">
          <a href="/work">WORK</a>
          <a href="/writing">PLAYGROUND</a>
          <a href="/about">ABOUT</a>
        </nav>
      </div>
    </footer>
    <script>
      import '../scripts/site-interactions';
    </script>
  </body>
</html>
