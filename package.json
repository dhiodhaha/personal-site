{
  "name": "dhafin-personal-site",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "cf:deploy": "wrangler deploy --config dist/server/wrangler.json",
    "cf:dev": "wrangler dev --config dist/server/wrangler.json",
    "cf:versions:deploy": "wrangler versions deploy --config dist/server/wrangler.json",
    "cf:triggers:deploy": "wrangler triggers deploy --config dist/server/wrangler.json",
    "studio": "sanity dev",
    "studio:deploy": "sanity deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@sanity/client": "^7.22.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "jose": "^6.2.3",
    "sanity": "^5.23.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@sanity/cli": "^6.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.87.0"
  }
}
